# =============================================================
#  Cloud Advisor Multi-Agent System — Environment Configuration
# =============================================================

# --- OpenAI (default) ---
OPENAI_API_KEY=your_openai_api_key_here

# --- Azure OpenAI (optional — set USE_AZURE_OPENAI=true to enable) ---
USE_AZURE_OPENAI=false
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01

# --- Model Settings ---
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096

# --- Conversation Settings ---
# Modes: interactive | batch
CONVERSATION_MODE=interactive

# Max rounds before forcing summary
MAX_CONVERSATION_ROUNDS=30

# --- Output ---
SAVE_REPORT=true
REPORT_OUTPUT_DIR=./reports
